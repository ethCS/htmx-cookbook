{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "api",
          "region": "us-central1"
        }
      }
    ]
  },
  "functions": {
    "source": ".",
    "runtime": "nodejs22"
  }
}
