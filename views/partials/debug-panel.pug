if debugInfo && debugInfo.length
  details.debug-panel
    summary Debug Details
    .debug-panel-body
      p.debug-panel-copy Expand for raw request and session diagnostics.
      dl.debug-grid
        each item in debugInfo
          dt= item.label
          dd
            pre= item.value
      .debug-panel-client(data-debug-client)
        h3.debug-panel-subtitle Browser View
        dl.debug-grid
          dt Current URL
          dd
            pre(data-debug-field="href") Loading...
          dt Origin
          dd
            pre(data-debug-field="origin") Loading...
          dt Cookie Enabled
          dd
            pre(data-debug-field="cookieEnabled") Loading...
          dt document.cookie
          dd
            pre(data-debug-field="documentCookie") Loading...

