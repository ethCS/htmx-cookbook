{
  "name": "htmx-cookbook",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "check": "npm run check:syntax && npm run check:templates",
    "check:syntax": "node --check server.js && node --check public/app.js",
    "check:templates": "node scripts/verify-templates.mjs",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "deploy": "firebase deploy"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-session": "^1.18.2",
    "firebase-admin": "^13.5.0",
    "firebase-functions": "^6.6.0",
    "pug": "^3.0.3"
  }
}
